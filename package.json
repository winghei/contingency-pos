{
  "name": "contingency-pos",
  "version": "0.0.0",
  "author": "Sherwin Vizcara",
  "license": "MIT",
  "description": "Contingency POS",
  "keywords": [
    "angular",
    "material",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/winghei/contingency-pos"
  },
  "bugs": {
    "url": "https://github.com/winghei/contingency-pos/issues"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "github-build": "ng build --configuration production --base-href 'https://winghei.github.io/contingency-pos/'",
    "github-deploy": "npx angular-cli-ghpages --dir=dist/contingency-pos/browser --no-silent",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "dev": "concurrently \"npm run start\" \"npm run server:dev\"",
    "build:all": "npm run build && npm run server"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.6",
    "@angular/cdk": "^20.0.5",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.5",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/service-worker": "^20.2.4",
    "@google/generative-ai": "^0.24.1",
    "@types/jspdf": "^1.3.3",
    "@types/uuid": "^10.0.0",
    "bootstrap": "^5.3.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jspdf": "^3.0.2",
    "multer": "^2.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@angular/build": "^20.0.5",
    "@angular/cli": "^20.0.5",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/pwa": "^20.2.2",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.10",
    "typescript": "~5.8.2"
  },
  "backendDependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  }
}
